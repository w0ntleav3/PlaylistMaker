<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/side_margin"
    android:background="@drawable/bg_bottom_sheet">

    <View
        android:layout_width="@dimen/bottom_sheet_handle_width"
        android:layout_height="@dimen/bottom_sheet_handle_height"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/margin_8dp"
        android:background="#CCCCCC" />

    <TextView
        style="@style/Text.Medium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/bottom_sheet_title_margin_top"
        android:fontFamily="@font/yandexsanstext_medium"
        android:textSize="@dimen/bottom_sheet_title_size"
        android:text="@string/add_to_playlist" />

    <Button
        android:id="@+id/btn_new_playlist_bottom"
        style="@style/Button.Primary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/bottom_sheet_button_margin_top"
        android:text="@string/new_playlist"
        app:cornerRadius="@dimen/button_corner_radius" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/playlists_recycler_bottom"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/margin_24dp"
        android:layout_marginBottom="@dimen/margin_24dp" />

</LinearLayout>